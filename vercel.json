{
    "functions": {
        "api/*.js": {
            "runtime": "@vercel/node@3"
        }
    },
    "routes": [
        {
            "src": "/api/auth/(.*)",
            "dest": "/api/auth.js?action=$1"
        },
        {
            "src": "/api/projects/([^/]+)",
            "dest": "/api/projects.js?id=$1"
        },
        {
            "src": "/api/projects",
            "dest": "/api/projects.js"
        },
        {
            "src": "/api/skills/([^/]+)",
            "dest": "/api/skills.js?id=$1"
        },
        {
            "src": "/api/skills",
            "dest": "/api/skills.js"
        },
        {
            "src": "/api/experiences/([^/]+)",
            "dest": "/api/experiences.js?id=$1"
        },
        {
            "src": "/api/experiences",
            "dest": "/api/experiences.js"
        },
        {
            "src": "/api/general",
            "dest": "/api/general.js"
        },
        {
            "src": "/api/messages/([^/]+)",
            "dest": "/api/messages.js?id=$1"
        },
        {
            "src": "/api/messages",
            "dest": "/api/messages.js"
        },
        {
            "src": "/api/upload",
            "dest": "/api/upload.js"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "status": 404,
            "dest": "/404.html"
        }
    ]
}