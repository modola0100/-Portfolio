{
    "buildCommand": "",
    "installCommand": "",
    "outputDirectory": ".",
    "framework": null,
    "routes": [
        {
            "src": "/api/git-sync",
            "dest": "/api/git-sync.js"
        },
        {
            "src": "/admin/?$",
            "dest": "/admin/admin.html"
        },
        {
            "src": "/admin/.*",
            "dest": "/admin/admin.html"
        },
        {
            "src": "/clear-storage",
            "dest": "/clear-storage.html"
        },
        {
            "src": "/([^/]*\\.(?:css|js|svg|png|jpg|jpeg|gif|ico|woff|woff2|json))$",
            "dest": "/$1"
        },
        {
            "src": "/src/(.*)$",
            "dest": "/src/$1"
        },
        {
            "src": "/admin/(.*)$",
            "dest": "/admin/$1"
        },
        {
            "handle": "filesystem"
        }
    ]
}
