{
    "buildCommand": null,
    "outputDirectory": ".",
    "rewrites": [
        {
            "source": "/api/auth/login",
            "destination": "/api/auth/login.js"
        },
        {
            "source": "/api/auth/register",
            "destination": "/api/auth/register.js"
        },
        {
            "source": "/api/auth/verify",
            "destination": "/api/auth/verify.js"
        },
        {
            "source": "/api/auth/forgot-password",
            "destination": "/api/auth/forgot-password.js"
        },
        {
            "source": "/api/auth/reset-password",
            "destination": "/api/auth/reset-password.js"
        },
        {
            "source": "/api/auth/refresh",
            "destination": "/api/auth/refresh.js"
        },
        {
            "source": "/api/auth/me",
            "destination": "/api/auth/me.js"
        },
        {
            "source": "/api/projects/:id",
            "destination": "/api/projects/[id].js?id=:id"
        },
        {
            "source": "/api/projects",
            "destination": "/api/projects/index.js"
        },
        {
            "source": "/api/skills/:id",
            "destination": "/api/skills/[id].js?id=:id"
        },
        {
            "source": "/api/skills",
            "destination": "/api/skills/index.js"
        },
        {
            "source": "/api/experiences/:id",
            "destination": "/api/experiences/[id].js?id=:id"
        },
        {
            "source": "/api/experiences",
            "destination": "/api/experiences/index.js"
        },
        {
            "source": "/api/general",
            "destination": "/api/general/index.js"
        },
        {
            "source": "/api/messages/:id",
            "destination": "/api/messages/[id].js?id=:id"
        },
        {
            "source": "/api/messages",
            "destination": "/api/messages/index.js"
        },
        {
            "source": "/api/upload",
            "destination": "/api/upload/index.js"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "GET, POST, PUT, DELETE, OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type, Authorization"
                }
            ]
        }
    ]
}